{
  "fingerprintId": "minio_any",
  "name": "minio",
  "protocol": "http",
  "tags": ["storage", "s3", "devops"],
  "info": {
    "version": "any",
    "author": "leo-seed",
    "description": "通过 /minio/health/live 探针或 x-amz-request-id 响应头识别 MinIO 对象存储服务。",
    "vulnerabilities": [
      {
        "title": "集群环境变量泄露（含 Secret Key）",
        "cve": "CVE-2023-28432",
        "severity": "critical",
        "description": "MinIO 集群部署中，/minio/health/cluster 接口可泄露环境变量，包含 MINIO_SECRET_KEY 等敏感凭证，进而导致对象存储完全接管。",
        "references": ["https://nvd.nist.gov/vuln/detail/CVE-2023-28432"]
      }
    ]
  },
  "rule": {
    "requests": [
      {
        "method": "GET",
        "uri": "/minio/health/live",
        "timeout": 3000,
        "charset": "UTF-8",
        "maxBodyBytes": 65536
      }
    ],
    "script": "var h = String(headers || '').toLowerCase(); status == 200 && (h.indexOf('x-amz-request-id') >= 0 || h.indexOf('x-minio') >= 0)"
  }
}
